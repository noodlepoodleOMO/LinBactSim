% 2 - Perona malik heat equation
% basically uses a heat equation to blur the image iteratively, but
% implements a gradient in the denominator so that high gradient edges are
% preserved, you can tweak the parameters to modify what threshold to pick
% as "an edge to preserve"
raw1 = readcell('../simulated-data/non-uni-traj/MM_100_be.xlsx');
raw2 = readcell('../simulated-data/non-uni-traj/MM_100_te.xlsx');

mazeH = size(UniformMaze, 2);
mazeW = size(UniformMaze, 1);
heatmap = zeros(mazeH, mazeW);

% accumulate visits from both files
