function heatmap = accumulate_traj(raw, heatmap)
    for col = 1:size(raw, 2)
        for row = 1:size(raw, 1)
            cell_val = raw{row, col};
            if ~ischar(cell_val) && ~isstring(cell_val), continue, end
            nums = sscanf(string(cell_val), '[%f, %f]');
            if numel(nums) < 2, continue, end
            % here sometimes you need to experiment with +1, -1 to get rid
            % of the wrong shifting between the maze mask and the heatmap 2d array, i'm not sure why that happens, and why the +1/-1
            % adjustements are inconsistent between the open plaza/uni/non uniform mazes
            x = round(nums(1)) +1; %+1
            y = round(nums(2)) +1; %-1
            heatmap(y, x) = heatmap(y, x) + 1;
        end
    end
end

