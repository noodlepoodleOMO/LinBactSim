heatmap = accumulate_traj(raw2, heatmap);

heatmap = heatmap.';

% plot with plasma, walls black
figure;
open_mask = (UniformMaze == 0);

% the median picks the edge scale from the data, change the factor to make
% the edge criteria softer (higher kappa) or harsher (lower kappa)
kappa  = 3 * median(heatmap(open_mask & heatmap > 0));
niter  = 5; % number of iterations, obv the more iter the more blur
lambda = 0.2; % step size
heatmap_smooth = masked_pm(heatmap, open_mask, niter, kappa, lambda);

