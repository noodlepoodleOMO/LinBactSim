% right now the PM algorithm only considers the 4 neighboring pixel values.
% could implement a version where it looks at a more extensive neighboring
% window

function out = masked_pm(I, mask, niter, kappa, lambda)
    % Masked Perona-Malik diffusion.
    %   I : 2d data array
    %   mask : false = wall
    %   niter: nb of iter
    %   kappa : conduction (edge) scale, same units as I
    %   lambda : step size, <= 0.25 for 4-neighbour stability
    I = double(I);  I(~mask) = 0; % mask is true for open cells, this makes wall positions=0 in I
    m = double(mask);
    g = @(d) exp(-(d./kappa).^2); % Perona Malik: 1./(1+(d/kappa).^2)
    for t = 1:niter
        % differences to the four neighbours (neighbour minus centre)
        dN = circshift(I, [ 1  0]) - I;
        dS = circshift(I, [-1  0]) - I;
        dE = circshift(I, [ 0 -1]) - I;
        dW = circshift(I, [ 0  1]) - I;
        
        % "conductance" in each direction, gated by whether that neighbour is open
        cN = g(dN) .* circshift(m, [ 1  0]);   % e.g.: 0 if north neighbour is a wall
        cS = g(dS) .* circshift(m, [-1  0]);
        cE = g(dE) .* circshift(m, [ 0 -1]);
        cW = g(dW) .* circshift(m, [ 0  1]);
        
        % update
        I = I + lambda*(cN.*dN + cS.*dS + cE.*dE + cW.*dW);
        I(~mask) = 0;
    end
    out = I;
end
